# __ Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ── Database
MONGODB_URI=mongodb://localhost:27017/kisan_saathi
# Production: mongodb+srv://user:pass@cluster.mongodb.net/kisan_saathi

# ── Auth 
JWT_SECRET=change-this-to-a-long-random-string-in-production

# ── SMS (OTP) — Choose one 
# Option A: Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Option B: MSG91 (cheaper for India, recommended)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=KISSAN

# ── LLM Provider — Choose one 
# The chatbot USP. Pick based on cost/performance needs.
# Recommended: claude-haiku-4-5 (fast, cheap, good Hindi) or gpt-4o-mini
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Or use OpenAI:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=

# Or use Gemini (free tier available):
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=

# ── File Storage
# Cloudinary for community post images
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── External Data APIs 
# Agmarknet API for real mandi rates (government portal)
AGMARKNET_API_KEY=
AGMARKNET_API_URL=https://agmarknet.gov.in/SearchCmmMkt.aspx

# IMD Weather (optional — for weather context in chatbot)
IMD_API_KEY=

# ── Caching 
# Redis for mandi rate cache (optional but recommended)
REDIS_URL=redis://localhost:6379
MANDI_CACHE_TTL_SECONDS=3600

# ── Monitoring (Production) 
SENTRY_DSN=
